{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Amiga E",
	"scopeName": "source.e",
	"patterns": [
		{
			"include": "#keyword-deprecated"
		},
		{
			"include": "#comment"
		},
		{
			"include": "#section"
		},
		{
			"include": "#keyword-general"
		},
		{
			"include": "#storage"
		},
		{
			"include": "#punctuation"
		},
		{
			"include": "#keyword-operator"
		},
		{
			"include": "#keyword-program-flow"
		},
		{
			"include": "#keyword-preprocessor"
		},
		{
			"include": "#string"
		},
		{
			"include": "#character"
		},
		{
			"include": "#constant-numeric"
		},
		{
			"include": "#constant-language"
		},
		{
			"include": "#function-name"
		},
		{
			"include": "#builtin-function-name"
		},
		{
			"include": "#label"
		},
		{
			"include": "#constant"
		},
		{
			"include": "#variable-language"
		},
		{
			"include": "#variable"
		}
	],
	"repository": {
		"keyword-deprecated": {
			"name": "invalid.deprecated.amiga-e",
			"match": "\\b(VOID)\\b"
		},
		"comment": {
			"name": "comment.amiga-e",
			"patterns": [
				{
					"include": "#comment-block"
				},
				{
					"include": "#comment-line"
				}
			],
			"repository": {
				"comment-block": {
					"name": "comment.block.amiga-e",
					"begin": "/\\*",
					"end": "\\*/"
				},
				"comment-line": {
					"name": "comment.line.amiga-e",
					"begin": "->",
					"end": "$"
				}
			}
		},
		"section": {
			"name": "keyword.SECTION.amiga-e",
			"match": "\\b(SECTION)\\s+?(CODE|DATA)\\s*?(,\\s*?(PUBLIC|FAST|CHIP))?\\b"
		},
		"keyword-general": {
			"name": "keyword.amiga-e",
			"match": "\\b(LIBRARY|EXTRA|IS|OPT|LARGE|STACK|ASM|NOWARN|DIR|OSVERSION|MODULE|EXPORT|RTD|020|881|882|040|060|REG|RUNBG|PURE|STRMERGE|POOL|FPEXP|INLINE|NOSTARTUP|UTILLIB|LEGACYINT|NEW|END|PTR TO|PTR|SIZEOF|PSIZEOF|ARRAYSIZE|OFFSETOF|OF|SUPER|ARRAY|STRING|LIST|BYTE|CHAR|INT|WORD|LONG|INCBIN|RAISE|WARN|FATAL)\\b"
		},
		"storage": {
			"name": "storage.amiga-e",
			"patterns": [
				{
					"include": "#storage-type-OBJECT"
				},
				{
					"include": "#storage-type-PROC"
				},
				{
					"include": "#storage-modifier-OBJECT"
				},
				{
					"include": "#storage-type-CONST"
				},
				{
					"include": "#storage-type-ENUM"
				},
				{
					"include": "#storage-type-SET"
				},
				{
					"include": "#storage-type-DEF"
				}
			],
			"repository": {
				"storage-type-OBJECT": {
					"name": "storage.type.OBJECT.amiga-e",
					"match": "\\b(OBJECT|ENDOBJECT)\\b"
				},
				"storage-modifier-OBJECT": {
					"name": "storage.modifier.OBJECT.amiga-e",
					"match": "\\b(NOALIGN|PRIVATE|PUBLIC|UNION|ENDUNION)\\b"
				},
				"storage-type-PROC": {
					"name": "storage.type.PROC.amiga-e",
					"match": "\\b(PROC|ENDPROC)\\b"
				},
				"storage-modifier-PROC": {
					"name": "storage.modifier.PROC.amiga-e",
					"match": "\\b(SAFE|GETA4|STACKCHECK|MODESETUP|MODCLEANUP|NOREGS|HANDLE|WITH RTR|WITH RTE)\\b"
				},
				"storage-type-CONST": {
					"name": "storage.type.CONST.amiga-e",
					"match": "\\b(CONST)\\b"
				},
				"storage-type-ENUM": {
					"name": "storage.type.ENUM.amiga-e",
					"match": "\\b(ENUM)\\b"
				},
				"storage-type-SET": {
					"name": "storage.type.SET.amiga-e",
					"match": "\\b(SET)\\b"
				},
				"storage-type-DEF": {
					"name": "storage.type.DEF.amiga-e",
					"match": "\\b(DEF)\\b"
				}
			}
		},
		"punctuation": {
			"name": "punctuation.separator.amiga-e",
			"match": "(,|;)"
		},
		"keyword-operator": {
			"name": "keyword.operator.amiga-e",
			"patterns": [
				{
					"include": "#keyword-operator-variable"
				},
				{
					"include": "#keyword-operator-math"
				},
				{
					"include": "#keyword-operator-math-word"
				},
				{
					"include": "#keyword-operator-compare"
				}
			],
			"repository": {
				"keyword-operator-variable": {
					"name": "keyword.operator.variable.amiga-e",
					"match": "(\\+\\+|\\-\\-|\\.|\\^|\\[|\\]|\\{|\\}|\\:=\\:|\\:=|\\:|\\?|\\s\\:\\s|==)"
				},
				"keyword-operator-math": {
					"name": "keyword.operator.math.amiga-e",
					"match": "(\\+=|\\-=|\\*=|/=|\\+|\\-|\\*|/|<<=|>>=|<<|>>|AND=|OR=|\\|\\|=)"
				},
				"keyword-operator-math-word": {
					"name": "keyword.operator.math.word.amiga-e",
					"match": "\\b(AND|OR|ANDALSO|ORELSE|NOT|INC|DEC)\\b"
				},
				"keyword-operator-compare": {
					"name": "keyword.operator.compare.amiga-e",
					"match": "(<>|>=|<=|=>|=<|>|<|=)"
				}
			}
		},
		"keyword-program-flow": {
			"name": "keyword.control.flow.amiga-e",
			"match": "\\b(IF|IFN|THEN|ELSEIF|ELSEIFN|ELSE|ENDIF|FOR|TO|STEP|DO|ENDFOR|WHILE|WHILEN|ELSEWHILE|ELSEWHILEN|ALWAYS|ENDWHILE|REPEAT|UNTIL|UNTILN|SELECT|CASE|DEFAULT|ENDSELECT|LOOP|ENDLOOP|BUT|RETURN|JUMP|EXIT|EXITN|CONT|CONTN|EXCEPT)\\b"
		},
		"keyword-preprocessor": {
			"name": "keyword.preprocessor.amiga-e",
			"match": "(#(define|undef|ifdef|ifndef|elifdef|else|endif|date))\\b"
		},
		"string": {
			"name": "string.quoted.double.amiga-e",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape.amiga-e",
					"match": "\\\\."
				}
			]
		},
		"character": {
			"name": "constant.character.amiga-e",
			"match": "\".{1,4}\""
		},
		"constant-numeric": {
			"name": "constant.numeric.amiga-e",
			"patterns": [
				{
					"include": "#numeric-hexadecimal"
				},
				{
					"include": "#numeric-binary"
				},
				{
					"include": "#numeric-float"
				},
				{
					"include": "#numeric-decimal"
				}
			],
			"repository": {
				"numeric-hexadecimal": {
					"name": "constant.numeric.hexadecimal.amiga-e",
					"match": "-?\\$\\h+?"
				},
				"numeric-binary": {
					"name": "constant.numeric.binary.amiga-e",
					"match": "-?\\%[0,1]+?"
				},
				"numeric-float": {
					"name": "constant.numeric.float.amiga-e",
					"match": "-?\\d+?\\.\\d+?|-?\\.\\d+?|-?\\d+?\\."
				},
				"numeric-decimal": {
					"name": "constant.numeric.decimal.amiga-e",
					"match": "-?\\d+?"
				}
			}
		},
		"constant-language": {
			"name": "constant.language.amiga-e",
			"match": "\\b(TRUE|FALSE|NIL|ALL|GADGETSIZE|OLDFILE|NEWFILE|READWRITE|EMPTY|STRLEN|TAG_DONE|TAG_END|TAG_IGNORE|TAG_MORE|TAG_SKIP|TAG_USER|OFFSET_BEGINNING|OFFSET_CURRENT|OFFSET_END)\\b"
		},
		"function-name": {
			"name": "entity.name.function.amiga-e",
			"match": "\\b(_?[a-z][a-zA-Z0-9_]*?)\\("
		},
		"builtin-function-name": {
			"name": "support.function.amiga-e",
			"match": "\\b([A-Z][a-zA-Z0-9_]*?)\\("
		},
		"label": {
			"name": "entity.name.section.amiga-e",
			"match": "^([a-zA-Z0-9_]*?):(?!=)"
		},
		"constant": {
			"name": "variable.other.const.amiga-e",
			"match": "\\b([A-Z]{1,2}[a-zA-Z0-9_]*?)\\b"
		},
		"variable-language": {
			"name": "variable.language.self.amiga-e",
			"match": "\\b(self)\\b"
		},
		"variable": {
			"name": "variable.other.readwrite.amiga-e",
			"match": "\\b([a-z][a-zA-Z0-9_]*?)\\b"
		}
	}
}